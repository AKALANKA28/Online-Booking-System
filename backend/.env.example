# Copy to `.env` in this same folder (never commit `.env`):
#   cp .env.example .env
#
# Run Compose from `backend/` so variables are substituted:
#   cd backend && docker compose up --build
#
# If any real API key was shared publicly, rotate it in the provider dashboard.

# --- shared secrets ---
INTERNAL_API_KEY=change-me-internal-key
JWT_SECRET=demo-demo-demo-demo-demo-demo-demo-12345

# --- RabbitMQ (optional overrides; Compose defaults guest/guest) ---
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# --- PostgreSQL (required for `docker compose` as written) ---
EVENT_DB_URL=jdbc:postgresql://localhost:5431/eventdb
EVENT_DB_USERNAME=ticketing
EVENT_DB_PASSWORD=ticketing

SEAT_DB_URL=jdbc:postgresql://localhost:5432/seatdb
SEAT_DB_USERNAME=ticketing
SEAT_DB_PASSWORD=ticketing

BOOKING_DB_URL=jdbc:postgresql://localhost:5433/bookingdb
BOOKING_DB_USERNAME=ticketing
BOOKING_DB_PASSWORD=ticketing

PAYMENT_DB_URL=jdbc:postgresql://localhost:5436/paymentdb
PAYMENT_DB_USERNAME=ticketing
PAYMENT_DB_PASSWORD=ticketing

# user-service (required unless you rely on compose defaults — see docker-compose.yml)
USER_DB_URL=jdbc:postgresql://localhost:5437/userdb
USER_DB_USERNAME=ticketing
USER_DB_PASSWORD=ticketing

# --- payment-notification-service: Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd

# --- payment-notification-service: SendGrid (email) ---
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=Ticketing Demo

# --- payment-notification-service: Twilio (SMS) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- user-service bootstrap (optional) ---
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@ticketing.local
ADMIN_PASSWORD=admin123
